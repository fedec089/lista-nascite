# Copia questo file in `.env` e compila i valori.
# ATTENZIONE: .env è nel .gitignore e NON deve mai essere committato.

# Personal Access Token Airtable con scope data.records:read e data.records:write sulla base.
VITE_AIRTABLE_TOKEN=

# ID della base Airtable (già configurato).
VITE_AIRTABLE_BASE_ID=appOT5B0zbZaCEQRZ

# Nome esatto della tabella.
VITE_AIRTABLE_TABLE=Regali
